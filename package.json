{
  "name": "slushie",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:push": "turbo db:push --filter=@slushie/db",
    "db:generate": "turbo db:generate --filter=@slushie/db"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5"
  },
  "packageManager": "npm@10.0.0"
}
